# Web UI — chat.pinaivu.ai
# Copy to .env.local and update values for your environment.

# Coordinator URL — the web UI talks directly to the coordinator (no gateway needed).
# When unset, uses mock responses for development.
PINAIVU_API_URL=https://13.206.80.190:4000

# Explorer-indexer URL — for the /r/:requestId detail page.
# When unset, uses mock data for development.
NEXT_PUBLIC_INDEXER_URL=http://localhost:3100

# Base domain for cross-subdomain navigation (chat.X, explorer.X)
# Leave empty for local dev (uses relative paths)
NEXT_PUBLIC_BASE_DOMAIN=pinaivu.com

# Sui zkLogin (Google OAuth + Enoki)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_ENOKI_NONCE_URL=https://api.enoki.mystenlabs.com/v1/zklogin/nonce
NEXT_PUBLIC_ENOKI_ZKP_URL=https://api.enoki.mystenlabs.com/v1/zklogin/zkp
NEXT_PUBLIC_SUI_NETWORK=testnet
