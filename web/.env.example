# Web UI — chat.pinaivu.ai
# Copy to .env.local and update values for your environment.

# Backend URL — coordinator or gateway. One call returns content directly.
# Local dev: https://13.206.80.190:4000 (coordinator direct)
# Production: https://13.206.80.190:4000 (or gateway at http://api.pinaivu.com:4001)
PINAIVU_API_URL=https://13.206.80.190:4000

# Model to use for inference (optional — auto-detects from coordinator if unset)
# PINAIVU_MODEL=gemma4-e4b-128k:latest

# Coordinator URL for fetching receipts (for detail page)
PINAIVU_COORDINATOR_URL=https://13.206.80.190:4000

# Explorer-indexer URL — for the /r/:requestId detail page and /explorer.
NEXT_PUBLIC_INDEXER_URL=http://api.pinaivu.com:3100

# Base domain for cross-subdomain navigation (chat.X, explorer.X)
# Leave empty for local dev (uses relative paths)
NEXT_PUBLIC_BASE_DOMAIN=pinaivu.com

# Sui zkLogin (Google OAuth + Enoki)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_ENOKI_NONCE_URL=https://api.enoki.mystenlabs.com/v1/zklogin/nonce
NEXT_PUBLIC_ENOKI_ZKP_URL=https://api.enoki.mystenlabs.com/v1/zklogin/zkp
NEXT_PUBLIC_SUI_NETWORK=testnet
