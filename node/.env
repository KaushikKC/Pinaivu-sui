# GPU Node
# Copy to .env and update values for your environment.

# Coordinator endpoint to register with
COORDINATOR_URL=https://13.206.80.190:4000

# Dev only — trusts coordinator's self-signed cert
INSECURE_COORDINATOR=1

# Sui address to receive payouts
PAYOUT_ADDRESS=0x_your_sui_address_here

# Ollama endpoint (local LLM backend)
OLLAMA_URL=http://localhost:11434
