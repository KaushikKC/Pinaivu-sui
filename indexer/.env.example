# Explorer-indexer — backs explorer.pinaivu.com
# Copy to .env and update values for your environment.

# READ-ONLY role against the coordinator's Postgres — do not give write access
DATABASE_URL=postgres://pinaivu:pinaivu@localhost:5435/indexer

INDEXER_BIND=0.0.0.0:3100

# Walrus publisher for archive cron
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# How many hours before a receipt gets archived to Walrus (0 = immediate, for dev)
ARCHIVE_AFTER_HOURS=0

RUST_LOG=pinaivu_indexer=info
