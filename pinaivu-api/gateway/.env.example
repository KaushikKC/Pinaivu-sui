# Gateway — backs api.pinaivu.com
# Copy to .env and fill in real values.

DATABASE_URL=postgres://pinaivu:pinaivu@localhost:5434/pinaivu
REDIS_URL=redis://localhost:6381

# Coordinator HTTPS endpoint
COORDINATOR_URL=

# Must match dashboard's ADMIN_SECRET
ADMIN_SECRET=

PORT=4001

# Dev only — remove in production
NODE_TLS_REJECT_UNAUTHORIZED=0
